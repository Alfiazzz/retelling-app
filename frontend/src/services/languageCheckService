// Простая эвристическая проверка "это похоже на русский текст или нет".
// Используется и для распознанного OCR-текста, и для распознанной речи —
// в обоих случаях у нас уже есть готовая строка результата, и проверка
// просто считает долю кириллических букв среди всех буквенных символов.
// Это не настоящая языковая детекция (NLP/AI), а быстрая локальная
// эвристика: она ловит явный случай "текст целиком на другом языке",
// но не задерживает пользователя ни на миллисекунду, так как работает
// над уже полученным текстом без сети и без дополнительных AI-вызовов.

// Ниже какой доли кириллицы среди букв считаем, что язык, скорее всего,
// не русский. Порог занижен умышленно (а не, например, 0.9), чтобы не
// ложно срабатывать на нормальном русском тексте с иностранными именами,
// терминами или отдельными вставками — нужен явный, грубый перекос в
// сторону другого алфавита, а не любая примесь латиницы.
const CYRILLIC_RATIO_THRESHOLD = 0.5

// Слишком короткие тексты не дают статистически надёжной доли (например,
// "OK" — 0% кириллицы, но это не повод бить тревогу при паре случайных
// латинских символов в начале распознавания). Ниже этого количества
// буквенных символов проверку просто пропускаем.
const MIN_LETTERS_FOR_CHECK = 15

/**
 * Определяет, похож ли текст на русский, по доле кириллических букв.
 * @param {string} text
 * @returns {{ looksRussian: boolean, cyrillicRatio: number, lettersCount: number }}
 */
export function checkLooksRussian(text) {
  const cleaned = (text ?? '')
  const cyrillicLetters = cleaned.match(/[а-яёА-ЯЁ]/g) ?? []
  const latinLetters    = cleaned.match(/[a-zA-Z]/g) ?? []
  const lettersCount    = cyrillicLetters.length + latinLetters.length

  if (lettersCount < MIN_LETTERS_FOR_CHECK) {
    // Недостаточно букв, чтобы делать вывод — считаем безопасным,
    // чтобы не блокировать короткие/только что начатые тексты.
    return { looksRussian: true, cyrillicRatio: 1, lettersCount }
  }

  const cyrillicRatio = cyrillicLetters.length / lettersCount
  return {
    looksRussian: cyrillicRatio >= CYRILLIC_RATIO_THRESHOLD,
    cyrillicRatio,
    lettersCount,
  }
}
