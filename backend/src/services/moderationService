// ── Нормализация текста ─────────────────────────────────────────────────────

const LOOKALIKE_MAP = {
  '0': 'о', 'o': 'о',
  '3': 'з',
  '4': 'ч',
  '6': 'б',
  'a': 'а', '@': 'а',
  'e': 'е', 'ё': 'е',
  'u': 'и', 'y': 'у',
  'i': 'и', '1': 'и', '!': 'и',
  'k': 'к',
  'h': 'н',
  'p': 'р',
  'c': 'с',
  't': 'т',
  'x': 'х',
  'b': 'в',
  'm': 'м',
  'n': 'п',
}

function normalize(rawText) {
  let text = (rawText ?? '').toLowerCase()
  text = text.replace(/[a-z0-9@!]/g, (ch) => LOOKALIKE_MAP[ch] ?? ch)
  text = text.replace(/([а-яё])[*_.,!?-]+(?=[а-яё])/g, '$1')
  text = text.replace(/([а-яё])\1+/g, '$1')
  text = text.replace(/[^а-яё\s]/g, ' ')
  text = text.replace(/\s+/g, ' ').trim()
  return text
}

// ── Вспомогательная функция поиска по списку фраз ───────────────────────────

function matchesAny(normalized, normalizedNoSpaces, phrases) {
  for (const phrase of phrases) {
    const normalizedPhrase = normalize(phrase)
    if (!normalizedPhrase) continue
    if (normalizedPhrase.includes(' ')) {
      if (normalized.includes(normalizedPhrase)) return true
    } else {
      if (normalized.includes(normalizedPhrase) ||
          normalizedNoSpaces.includes(normalizedPhrase.replace(/\s+/g, ''))) return true
    }
  }
  return false
}

// ── Основная проверка ───────────────────────────────────────────────────────

/**
 * Проверяет текст на запрещённый контент и попытки prompt injection.
 * @param {string} text
 * @returns {{
 *   safe: boolean,
 *   type: 'prohibited' | 'injection' | null,
 *   category: string | null
 * }}
 *
 * type === 'prohibited' → жёсткая блокировка (мат, суицид, насилие и т.д.)
 * type === 'injection'  → мягкая блокировка (просьба переформулировать)
 * safe === true         → текст прошёл проверку
 */
export function checkContent(text) {
  if (!text || !text.trim()) return { safe: true, type: null, category: null }

  const normalized = normalize(text)
  const normalizedNoSpaces = normalized.replace(/\s+/g, '')

  // Сначала — prohibited (приоритет выше: мат/суицид важнее injection)
  for (const [category, words] of Object.entries(PROHIBITED_CATEGORIES)) {
    if (matchesAny(normalized, normalizedNoSpaces, words)) {
      return { safe: false, type: 'prohibited', category }
    }
  }

  // Затем — injection
  if (matchesAny(normalized, normalizedNoSpaces, INJECTION_PHRASES)) {
    return { safe: false, type: 'injection', category: 'promptInjection' }
  }

  return { safe: true, type: null, category: null }
}
