PORT=3001

# AI провайдер: groq или gemini
AI_PROVIDER=groq

# Groq API — https://console.groq.com (бесплатно)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini API — https://aistudio.google.com (бесплатно)
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Resend — https://resend.com (бесплатно до 3000 писем/мес)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Адрес фронтенда (для CORS)
FRONTEND_URL=http://localhost:5173

# От кого отправляются письма (должен быть верифицированный домен в Resend)
# На старте можно использовать onboarding@resend.dev (только для теста)
EMAIL_FROM=onboarding@resend.dev
